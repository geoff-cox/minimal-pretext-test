<?xml version='1.0' encoding='utf-8'?>
<pretext xml:lang="en-US" xmlns:xi="http://www.w3.org/2001/XInclude">

  <article>
    <title>Question Previewer</title>
    
    <section>
      <title>TITLE</title>

      <exercise xml:id="proteus-5-3-matching-1" label="proteus-5-3-matching-1">
        <title>Composition Matching</title>
        
        <statement>
          <p>
            <md>
              2 (2x+5)^7 = f(g(x)) g'(x)
            </md>
            Drag the cards from the left column into the correct labels in the right column.
          </p>
        </statement>

        <cardsort>
          <match>
            <premise><m>2x+5</m></premise>
            <response>Inner function <m>g(x)</m></response>
          </match>
          <match>
            <premise><m>2</m></premise>
            <response>Derivative of inner function <m>g'(x)</m></response>
          </match>
          <match>
            <premise><m>x^7</m></premise>
            <response>Outer function <m>f(x)</m></response>
          </match>
        </cardsort>
      </exercise>
    </section>

  </article>

</pretext>